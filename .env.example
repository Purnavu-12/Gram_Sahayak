# Gram Sahayak Environment Configuration
# Copy this file to .env and fill in your values

# MyScheme.gov.in API Configuration (OPTIONAL)
# Only needed if you want to sync the database using schemes_agent.py
# The voice agent uses DuckDuckGo webscraping instead (no API key required)
# Get your API key from https://api.myscheme.gov.in/
MYSCHEME_API_KEY=your_api_key_here

# LiveKit Configuration (for voice agent)
# Get these from your LiveKit Cloud account or self-hosted server
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Google AI Configuration (for voice agent LLM)
# Get from https://ai.google.dev/
GOOGLE_API_KEY=your_google_api_key

# Database Configuration
DB_PATH=./schemes.db

# Sync Configuration
SYNC_INTERVAL_HOURS=1
