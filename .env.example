# Gram Sahayak Environment Configuration
# Copy this file to .env and fill in your values

# LiveKit Configuration (for voice agent)
# Get these from your LiveKit Cloud account or self-hosted server
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Google AI Configuration (for voice agent LLM)
# Get from https://ai.google.dev/
GOOGLE_API_KEY=your_google_api_key

# Token Server (serves JWT tokens for frontend → LiveKit connection)
TOKEN_SERVER_PORT=8081

# Database Configuration
DB_PATH=./schemes.db
